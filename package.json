{
  "name": "stormont",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "dev:fresh": "next dev",
    "start": "next start",
    "lint": "eslint app lib components --ext .ts,.tsx",
    "pages:build": "vercel build && npx @cloudflare/next-on-pages",
    "pages:preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "sync": "tsx scripts/sync.ts",
    "sync:full": "tsx scripts/sync-full.ts",
    "sync:members": "tsx scripts/sync-members.ts",
    "sync:hansard": "tsx scripts/sync-hansard.ts",
    "sync:motion-text": "tsx scripts/sync-motion-text.ts",
    "sync:structure": "tsx scripts/sync-structure.ts",
    "sync:bills": "npx tsx scripts/sync-bills.ts",
    "sync:contacts": "npx tsx scripts/sync-contact-details.ts",
    "backfill:titles": "npx tsx scripts/backfill-titles.ts",
    "download-images": "npx tsx scripts/download-mla-images.ts",
    "sync:question-stats": "npx tsx scripts/sync-question-stats.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "^1.19.4",
    "@types/d3": "^7.4.3",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.15",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vercel": "^47.1.4",
    "wrangler": "^4.85.0"
  }
}
